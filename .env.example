# Copy to .env and fill in values. Never commit .env.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cu_market_intelligence

# Anthropic API — used by /ask NL query endpoint
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret for tenant authentication
JWT_SECRET=change-me-to-a-random-secret

# Census Bureau API key (free at api.census.gov/data/key_signup.html)
# Requests work without a key but are rate-limited more aggressively
CENSUS_API_KEY=

# Directory where generated .docx reports are saved
REPORTS_DIR=data/reports

# Comma-separated list of allowed CORS origins (use * for dev)
ALLOWED_ORIGINS=http://localhost:5173

# Frontend: API base URL
VITE_API_URL=http://localhost:8000
